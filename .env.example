# Firebase Configuration Template
# Copy this file to .env.local and fill in your actual values

# Your Firebase project ID (from Firebase Console)
FIREBASE_PROJECT_ID=vidyalayam-288fd

# Firebase service account email (from Service Account JSON)
FIREBASE_CLIENT_EMAIL=your-service-account-email@vidyalayam-288fd.iam.gserviceaccount.com

# Firebase private key (from Service Account JSON) - Keep the newlines as \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPaste-your-actual-private-key-here\n-----END PRIVATE KEY-----\n"

# Next.js API URL
NEXT_PUBLIC_API_URL=http://localhost:5000
